		<dc:title id="title">The Perfume of Eros</dc:title>
		<meta property="file-as" refines="#title">Perfume of Eros, The</meta>
		<meta property="dcterms:alternative" refines="#title">The Yellow Fay</meta>
		<dc:subject id="subject-1">New York (N.Y.) -- Fiction</dc:subject>
		<dc:subject id="subject-2">Man-woman relationships -- Fiction</dc:subject>
		<dc:subject id="subject-3">Trials (Murder) -- Fiction</dc:subject>
		<dc:subject id="subject-4">Murder -- Fiction</dc:subject>
